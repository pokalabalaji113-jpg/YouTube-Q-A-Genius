# ============================================
# YouTube Q&A Genius - Environment Variables
# ============================================

# Choose ONE LLM Provider:

# Option 1: OpenAI (GPT-4)
OPENAI_API_KEY = "your_openai_api_key"

# Option 2: Groq (FREE - Recommended for students)
GROQ_API_KEY = "your_groq_api_key"

# LLM Provider Selection: "openai" or "groq"
LLM_PROVIDER=groq

# LLM Model
# For Groq: llama3-70b-8192 or mixtral-8x7b-32768
# For OpenAI: gpt-4o or gpt-3.5-turbo
LLM_MODEL=llama3-70b-8192

# ChromaDB persistence directory
CHROMA_DB_DIR=./chroma_db

# App Settings
APP_TITLE=YouTube Q&A Genius
MAX_TRANSCRIPT_CHUNKS=500
